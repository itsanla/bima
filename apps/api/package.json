{
  "name": "api",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc",
    "clean-install": "rm -rf ./node_modules && rm -r package-lock.json && npm i",
    "dev:basic": "cross-env DOTENV_CONFIG_PATH=./config/.env.development ts-node ./src/main",
    "dev:watch": "nodemon --exec \"npm run dev:basic\" --watch ./src --ext .ts",
    "dev": "concurrently \"npm run dev:watch\" \"npm run sync\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node ./dist/main.js",
    "sync": "delay 1s && browser-sync start --config bs-config.js",
    "test": "cross-env NODE_ENV=test vitest",
    "type-check": "tsc -b --noEmit"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "_moduleAliases": {
    "@src": "dist"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "jet-logger": "^2.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.41",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.1.0",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "pg": "^8.22.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@swc/core"
    ]
  }
}
